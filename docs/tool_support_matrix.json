          "support": { "ferro": {"validate":"yes","normalize":"full"}, "mutalyzer": {"validate":"yes","normalize":"full"}, "biocommons": {"validate":"yes","normalize":"full"}, "hgvs-rs": {"validate":"permissive","normalize":"full"} } },
